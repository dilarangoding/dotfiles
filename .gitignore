# System and Editor files
*.log
*.cache
*.pid
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# Zsh specific
.zsh_history
.zsh_sessions/
.zcompdump*

# Neovim
nvim/.config/nvim/.netrwhist
nvim/.config/nvim/plugin/
nvim/.config/nvim/lazy-lock.json
nvim/.config/nvim/spell/
nvim/.config/nvim/.luarc.json
nvim/.config/nvim/lua/.luarc.json

# Lazygit state
.config/lazygit/state.yml

# Newsboat cache (keep urls and config, ignore cache)
newsboat/.newsboat/cache.db
newsboat/.newsboat/*.db

# Joplin (ignore everything except keymap)
joplin/.config/joplin/*
!joplin/.config/joplin/keymap.json

# Tmux (ignore tmux plugin data except tmuxifier)
tmux/.config/tmux/plugins/*
!tmux/.config/tmux/plugins/tmuxifier

# st build artifacts
st/st-src/st
st/st-src/*.o
st/st-src/*.tar.gz
st/st-src/*.orig
st/st-src/*.rej

# SSH and Security
*.pem
*.key
id_rsa*
id_ed25519*
*.gpg
*.asc

# Secrets and Environment
*password*
*secret*
.env
.env.*
*.env.local

# Backup files
*.bak
*.backup
*.old
*_backup

# Compiled files
*.pyc
*.so
*.class

# IDE specific
.vscode/
.idea/
*.code-workspace

# Temporary directories
tmp/
temp/
cache/

# Dependencies
node_modules/
vendor/
.npm/
.cargo/

# Local configs
*local.conf
*local.toml
*.local

# Keep empty directories
!.gitkeep
