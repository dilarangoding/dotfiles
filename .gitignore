# System and Editor files
*.log
*.cache
*.pid
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# Zsh specific
.zsh_history
.zsh_sessions/
.zcompdump*

# Neovim (new path: .config/nvim/)
.config/nvim/.netrwhist
.config/nvim/plugin/
.config/nvim/lazy-lock.json
.config/nvim/spell/
.config/nvim/.luarc.json
.config/nvim/lua/.luarc.json

# Lazygit state
.config/lazygit/state.yml

# Newsboat cache (keep urls and config, ignore cache)
.config/newsboat/cache.db
.config/newsboat/*.db

# Joplin (ignore everything except keymap)
.config/joplin/*
!.config/joplin/keymap.json
!.config/joplin/.gitkeep

# Tmux (ignore tmux plugin manager data)
.config/tmux/plugins/*
!.config/tmux/plugins/tmuxifier

# SSH and Security
*.pem
*.key
id_rsa*
id_ed25519*
*.gpg
*.asc

# Secrets and Environment
*password*
*secret*
.env
.env.*
*.env.local

# Backup files
*.bak
*.backup
*.old
*_backup

# Compiled files
*.pyc
*.o
*.so
*.class

# IDE specific
.vscode/
.idea/
*.code-workspace

# Temporary directories
tmp/
temp/
cache/

# Dependencies
node_modules/
vendor/
.npm/
.cargo/

# Local configs
*local.conf
*local.toml
*.local

# Local directory - ignore data/state, track bin
.local/share/*
.local/state/*
!.local/bin/
!.local/bin/**

# Keep empty directories
!.gitkeep
